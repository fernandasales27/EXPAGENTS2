# EMAIL_SENDER_MODE:
# - smtp: exige SMTP configurado e envia email real (recomendado para uso real)
# - auto: usa SMTP se estiver completo, senao cai para console
# - console: nunca envia email real
EMAIL_SENDER_MODE=smtp

# Se nao configurar as variaveis abaixo e EMAIL_SENDER_MODE=auto, o backend usa envio por console.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario
SMTP_PASS=senha
SMTP_FROM=professor@example.com

# Scheduler diario de envio consolidado.
# true = habilita execucao automatica diaria.
ENABLE_EMAIL_SCHEDULER=true
# Horario de disparo no formato HH:MM.
EMAIL_DISPATCH_TIME=23:59
